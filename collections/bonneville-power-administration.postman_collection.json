  "info": {
    "_postman_id": "38124230-bda8-44be-8435-3ecc25bec598",
    "name": "Bonneville Power Administration GIS Hub API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "BPA GIS Data Hub serves public geospatial data via ArcGIS Online Feature\nServices. Each layer is exposed as a standard ArcGIS REST FeatureServer\nsupporting query, format conversion, replica creation, and size estimates.\nThe endpoints below cover the published BPA layers (service area, customer\nclasses, transmission lines, transmission structures, right-of-way, and\nColumbia River Basin).\n\n\nContact Support:\n Name: BPA GIS Data Hub",
      "type": "text/plain"
    }
  }
